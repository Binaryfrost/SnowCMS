---
import { CMS_RENDER_HTML } from 'astro:env/server';
import { serialize } from '../util';

interface Props {
  data: Record<string, any>
}

const { data } = Astro.props;
---

{Object.keys(data).map((k) => (
  <>
    <h2>{k}</h2>
    {CMS_RENDER_HTML ? (
      <Fragment set:html={serialize(data[k])} />
    ) : (
      <pre>{serialize(data[k])}</pre>
    )}
  </> 
))}

<style>
  pre {
    white-space: pre-wrap;
  }
</style>